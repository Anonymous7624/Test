# Worker reuses `backend/.env` when you run from `backend/` (recommended).
# Optional overrides:

# Seconds between polling cycles (default 150 = 2.5 minutes)
# WORKER_POLL_SECONDS=150

# Same as backend if you split env files:
# DATABASE_URL=sqlite:///./data/app.db

# Step 3 Ollama (usually set in backend/.env — worker loads backend app settings):
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_TIMEOUT_SECONDS=300
# (legacy) OLLAMA_TIMEOUT=240
# Extra seconds on baseline timeout for strong / high-heuristic-profit candidates
# OLLAMA_TIMEOUT_STRONG_BONUS=30
# WORKER_STEP3_AI_CANDIDATE_MAX_SECONDS=660
# Max listings that receive an Ollama attempt per batch (rest use heuristic-only)
# WORKER_STEP3_AI_CAP=50
# WORKER_OLLAMA_STRONG_MIN_STRENGTH=0.72
# WORKER_OLLAMA_STRONG_MIN_HEURISTIC_PROFIT=25

# Step 1: visit Marketplace item pages (up to N) for richer description, brand, condition, images.
# WORKER_COLLECTOR_DETAIL_ENRICH_MAX=25
# Set to 0 to disable.

# Step 1: max raw listings collected per Playwright collector run.
# WORKER_COLLECTOR_BATCH_CAP overrides ALL modes (live + backfill + category-feed + keyword).
# WORKER_COLLECTOR_BATCH_CAP=30
#
# Category-feed live runs use a tighter default (15) to reduce wasted detail-page visits on
# listings that will later be rejected for location_outside_radius.  Card-visible location
# pre-screening (Step 1 early-loc-reject) removes obviously out-of-radius listings before
# any detail-page browser visits.  You can raise or lower this independently:
# WORKER_COLLECTOR_CATEGORY_FEED_BATCH_CAP=15

# --- Worker heartbeat ---
# Seconds before the API treats this worker as dead (must match backend WORKER_HEARTBEAT_STALE_SECONDS).
# Default: 300. Increase for very long Playwright sessions.
# WORKER_HEARTBEAT_STALE_SECONDS=300
