# Copy to `.env` in this directory (`backend/`). Run API and worker with cwd = `backend/`
# so relative SQLite path resolves consistently.

# --- Auth / JWT ---
SECRET_KEY=replace-with-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Default admin (seeded on API startup if no user with this username exists) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- MongoDB (users, settings, listings) ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=deal_dashboard

# --- Categories config (repo root) ---
CATEGORIES_PATH=../config/categories.json

# --- CORS (comma-separated Next.js origins; required when frontend host is not in the default list) ---
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.181:3000
# Legacy alias (optional): CORS_ORIGINS=...

# --- Telegram (optional; bot token on server only; each user sets chat id in Settings) ---
# TELEGRAM_BOT_TOKEN=

# --- Geoapify (server-side geocoding + boundaries when saving Settings; never commit real keys) ---
# GEOAPIFY_API_KEY=

# --- Ollama (Step 3 AI scoring; worker uses same vars via backend settings) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# Seconds (HTTP client timeout for /api/chat)
OLLAMA_TIMEOUT=180
